# x402 API Server Configuration
# Copy to .env and customize

# Your wallet address for receiving USDC payments on Base
PAY_TO_ADDRESS=0x60264c480b67adb557efEd22Cf0e7ceA792DefB7

# Server port
PORT=4020

# Environment: "production" or "development"
# - development: accepts mock payments (any X-PAYMENT header)
# - production: requires real on-chain USDC verification
NODE_ENV=development

# Base chain RPC URL (get a free one from Alchemy/QuickNode for production)
BASE_RPC_URL=https://mainnet.base.org

# EIP-3009 settlement configuration
# Modes:
# - auto: use direct settlement if a private key is configured, otherwise use a custom facilitator URL if provided
# - direct: submit transferWithAuthorization on-chain from this server
# - facilitator: forward settlement to a custom facilitator
# - disabled: txHash proof only
X402_SETTLEMENT_MODE=auto

# Direct settlement sponsor key (pays gas for transferWithAuthorization)
# Use a dedicated hot wallet with gas funds on Base, not your cold wallet.
# X402_SETTLEMENT_PRIVATE_KEY=0x...

# Optional custom facilitator for EIP-3009 settlement
# Do not point this at x402.org/facilitator for Base mainnet.
# X402_FACILITATOR_URL=https://your-facilitator.example.com
# X402_FACILITATOR_API_KEY=your-api-key
