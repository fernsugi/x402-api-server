# x402 API Server Configuration
# Copy to .env and customize

# Your wallet address for receiving USDC payments on Base
PAY_TO_ADDRESS=0x60264c480b67adb557efEd22Cf0e7ceA792DefB7

# Server port
PORT=4020

# Environment: "production" or "development"
# - development: accepts mock payments (any X-PAYMENT header)
# - production: requires real on-chain USDC verification
NODE_ENV=development

# Base chain RPC URL (get a free one from Alchemy/QuickNode for production)
BASE_RPC_URL=https://mainnet.base.org
